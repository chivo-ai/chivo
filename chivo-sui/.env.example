# Chivo Sui deploy env.
# Copy to .env inside chivo-sui and fill real values there.
# Do not commit .env.

SUI_NETWORK=testnet
SUI_TESTNET_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_GAS_BUDGET=100000000

# Sui deploy key is managed by the Sui CLI keystore, not this .env.
# In Codespaces, run `sui client new-address ed25519` or import a key,
# then switch the active Sui address before deploy.
SUI_ACTIVE_ADDRESS=
SUI_KEYSTORE_PATH=/home/codespace/.sui/sui_config/sui.keystore

# Empty before deploy/init. Fill from deploy-testnet.json and init-testnet.json.
SUI_PACKAGE_ID=
SUI_CONFIG_ID=

# Testnet can use the active Sui address for both values.
# Production should split treasury/operator accounts.
SUI_FEE_COLLECTOR=
SUI_PAYOUT_OPERATOR=

SUI_NATIVE_FEE_BPS=50
SUI_MAX_FEE_BPS=2500
SUI_AUTO_RELEASE_DELAY_MS=900000
