# Chivo EVM deploy env.
# Copy to .env inside chivo-evm and fill real values there.
# Do not commit .env.

ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY
EVM_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
EVM_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BNB_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BNB_WS_URL=wss://bnb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BNB_TESTNET_RPC_URL=https://bnb-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BNB_TESTNET_WS_URL=wss://bnb-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployer wallet private key.
# Use a funded BNB testnet wallet for testnet.
# Format: 0x followed by 64 hex characters.
EVM_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Testnet can use the deployer address for all roles.
# Production should split these into multisig/operator/treasury keys.
CHIVO_AUTHORIZER=
CHIVO_FEE_COLLECTOR=
CHIVO_PAYOUT_OPERATOR=
CHIVO_RISK_OPERATOR=

# Empty before deploy. Fill with printed router address after deploy.
CHIVO_PAYMENT_ROUTER=

ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
BSCSCAN_API_KEY=
